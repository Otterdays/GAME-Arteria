{
  "name": "arteria",
  "version": "1.0.0",
  "private": true,
  "main": "apps/mobile/index.js",
  "description": "Arteria — a math-heavy, incremental idle RPG for Android.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "cd apps/mobile && expo start",
    "android": "cd apps/mobile && expo start --android",
    "test:engine": "cd packages/engine && npm test",
    "ios": "expo run:ios",
    "build": "npm run build --workspace=@arteria/engine",
    "postinstall": "npm run build",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:suite": "jest --selectProjects suite"
  },
  "dependencies": {
    "expo": "~55.0.5",
    "expo-router": "~55.0.4",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-nitro-modules": "^0.35.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "babel-preset-expo": "^55.0.10",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
