{
  "expo": {
    "name": "Arteria",
    "slug": "arteria",
    "version": "0.5.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arteria",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "barStyle": "dark-content"
    },
    "ios": {
      "supportsTablet": true,
      "runtimeVersion": "0.5.2"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": true,
      "package": "com.anonymous.arteria.dev",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "runtimeVersion": "0.5.2"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-router",
      [
        "expo-updates",
        {
          "checkAutomatically": "ON_LAUNCH"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "../../node_modules/@expo-google-fonts/cinzel/400Regular/Cinzel_400Regular.ttf",
            "../../node_modules/@expo-google-fonts/cinzel/700Bold/Cinzel_700Bold.ttf"
          ]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "./plugins/withAbiSplits"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "708ed485-f6e9-4de5-96ff-91c92d09face"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/708ed485-f6e9-4de5-96ff-91c92d09face",
      "fallbackToCacheTimeout": 0
    }
  }
}